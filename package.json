{
  "name": "boce-aggregated-api-system",
  "version": "0.1.0",
  "description": "Unified API for Boce.com detection (website speed, DNS, etc.) with metrics and anomaly detection",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "mcp:start": "node dist/mcp/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "mcp:dev": "ts-node-dev --respawn --transpile-only src/mcp/server.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "bullmq": "^5.71.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "ioredis": "^5.4.1",
    "pg": "^8.20.0",
    "uuid": "^10.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.14.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
