# Boce API (get key from https://www.boce.com)
BOCE_API_KEY=your_boce_api_key_here
BOCE_BASE_URL=https://api.boce.com

# Server
PORT=3000
NODE_ENV=development

# Redis (used by docker-compose; local default below)
REDIS_URL=redis://localhost:6379
QUEUE_DISPATCH_INTERVAL_MS=1500
QUEUE_DISPATCH_BATCH_SIZE=200

# Postgres (Step 8 storage)
DATABASE_URL=postgresql://boce:boce@localhost:5432/boce_api

# Application-level default webhook (optional)
APP_WEBHOOK_URL=
WEBHOOK_SIGNING_SECRET=

# Client auth (commercial step; disabled by default for backward compatibility)
AUTH_ENABLED=false
# Static auth mode (single fixed key/client; no DB lookup)
AUTH_STATIC_MODE=false
AUTH_STATIC_CLIENT_ID=demo-client
AUTH_STATIC_API_KEY=change_me_to_strong_key
AUTH_STATIC_CLIENT_NAME=Static Client
AUTH_STATIC_MAX_BATCH_SIZE=5000
AUTH_STATIC_DEFAULT_WEBHOOK_URL=
# DB-backed bootstrap auth (used when AUTH_STATIC_MODE=false)
BOOTSTRAP_CLIENT_ID=demo-client
BOOTSTRAP_CLIENT_NAME=Demo Client
BOOTSTRAP_API_KEY=change_me_to_strong_key

# Admin token for key-management/admin APIs
ADMIN_TOKEN=change_me_admin_token
