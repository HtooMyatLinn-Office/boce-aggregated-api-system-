# Boce API (get key from https://www.boce.com)
BOCE_API_KEY=your_boce_api_key_here
BOCE_BASE_URL=https://api.boce.com

# Server
PORT=3000
NODE_ENV=development

# Redis (used by docker-compose; local default below)
REDIS_URL=redis://localhost:6379

# Postgres (Step 8 storage)
DATABASE_URL=postgresql://boce:boce@localhost:5432/boce_api

# Application-level default webhook (optional)
APP_WEBHOOK_URL=
