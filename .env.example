# Boce API (get key from https://www.boce.com)
BOCE_API_KEY=your_boce_api_key_here
BOCE_BASE_URL=https://api.boce.com

# Server
PORT=3000
NODE_ENV=development

# MCP Stream HTTP (@modelcontextprotocol/sdk Host validation). Required when exposing MCP behind a public domain.
# Comma-separated hostnames only (no port), e.g. boce-center.example.com
# MCP_ALLOWED_HOSTS=boce-center.example.com
# MCP token auth for HTTP transport (recommended on public deployment)
MCP_AUTH_ENABLED=false
MCP_AUTH_TOKEN=
# Allow token via URL query (?mcp_auth_token=...). Keep false unless client cannot send headers.
MCP_AUTH_ALLOW_QUERY_TOKEN=false

# Redis (used by docker-compose; local default below)
REDIS_URL=redis://localhost:6379
QUEUE_DISPATCH_INTERVAL_MS=1500
QUEUE_DISPATCH_BATCH_SIZE=200

# Postgres (Step 8 storage)
DATABASE_URL=postgresql://boce:boce@localhost:5432/boce_api

# Application-level default webhook (optional)
APP_WEBHOOK_URL=
WEBHOOK_SIGNING_SECRET=

# Client auth (commercial step; disabled by default for backward compatibility)
AUTH_ENABLED=false
# Static auth mode (single fixed key/client; no DB lookup)
AUTH_STATIC_MODE=false
AUTH_STATIC_CLIENT_ID=demo-client
AUTH_STATIC_API_KEY=change_me_to_strong_key
AUTH_STATIC_CLIENT_NAME=Static Client
AUTH_STATIC_MAX_BATCH_SIZE=5000
AUTH_STATIC_DEFAULT_WEBHOOK_URL=
# DB-backed bootstrap auth (used when AUTH_STATIC_MODE=false)
BOOTSTRAP_CLIENT_ID=demo-client
BOOTSTRAP_CLIENT_NAME=Demo Client
BOOTSTRAP_API_KEY=change_me_to_strong_key

# Admin token for key-management/admin APIs
ADMIN_TOKEN=change_me_admin_token

# Stream probe feature
STREAM_PLAYBACK_API_URL=
STREAM_PLAYBACK_API_METHOD=GET
STREAM_M3U8_FETCH_TIMEOUT_MS=15000
# Max playback sources to probe per region request (safe default)
STREAM_MAX_SOURCES=5
# Delay between per-source probes to avoid burst load
STREAM_PROBE_DELAY_MIN_MS=1000
STREAM_PROBE_DELAY_MAX_MS=2000
# Cache best ranking (10-30 minutes)
STREAM_CACHE_TTL_MIN_SEC=600
STREAM_CACHE_TTL_MAX_SEC=1800
# Probe node count cap
STREAM_MAX_NODES=3
